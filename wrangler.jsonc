{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-ts",
  "compatibility_date": "2026-06-04",
  "observability": {
    "enabled": true
  },
  "main": "@tanstack/react-start/server-entry",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "bodhi-mitra-assets"
    }
  ]
}
