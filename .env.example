# ──────────────────────────────────────────────────────────────
# Supabase Configuration — Bodhi Mitra CMS
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your Supabase project values.
# Get these from your Supabase project dashboard: Settings → API
# ──────────────────────────────────────────────────────────────

# Client-side variables (injected at build time by Vite)
#   Used in: src/integrations/supabase/client.ts
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-side variables (process.env, used in SSR / server code)
#   Used in: src/integrations/supabase/client.ts (SSR fallback)
#            src/integrations/supabase/client.server.ts
#            src/integrations/supabase/auth-middleware.ts
#            scripts/setup-demo.cjs
#            scripts/cleanup-demo.cjs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Management API token (starts with sbp_) — for database seeding
#   Falls back to SUPABASE_SERVICE_ROLE_KEY if not set
#   Used in: scripts/seed-db.mjs
#   Get from: Supabase Dashboard → Settings → API → Project API keys
SUPABASE_MANAGEMENT_KEY=sbp_your-management-token

# Site URL (used for Stripe redirect URLs and sitemap)
#   Falls back to VERCEL_URL or http://localhost:3000
SITE_URL=https://your-production-url.com

# Stripe Configuration (https://dashboard.stripe.com/apikeys)
#   Used in: src/integrations/stripe/server.ts
#            src/lib/stripe-checkout.ts
#            src/routes/api/stripe-webhook.ts
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
